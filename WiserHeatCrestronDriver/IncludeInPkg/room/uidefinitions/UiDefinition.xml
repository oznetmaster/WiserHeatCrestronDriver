<?xml version="1.0" encoding="utf-8" ?>
<uidefinition xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://prd-use-rad-assets.azurewebsites.net/ExtensionsSchemaDefinition.xsd">
  <version ver="2.0" />
  <tile icon="{tileIcon}" status="{currentTemperatureLabel}" navigation="show:MainPage" showinhomepage="#false" showinroompage="#true" />
  <layouts>
    <layout id="MainPage" title="{deviceLabel}" subtitle="{scheduleSummary}" isdefaultlayout="#true">
      <controls>
        <thermostat id="RoomThermostat" toplefticon="{tileIcon}" title="^ThermostatTitle|{deviceLabel}" setpointauto="{targetTemperature}" heatmodeenabled="#false" coolmodeenabled="#false" automodeenabled="#true" modeicon="{tileIcon}" currenttemperature="{currentTemperature}" currenttemperaturelabel="{currentTemperatureLabel}" temperatureunits="{temperatureUnits}" />
        <statusandbutton id="BoostButton" label="^BoostLabel" status="{boostStateLabel}" buttonlabel="{boostActionLabel}" buttonaction="command:boost" />
        <statusandbutton id="ScheduleButton" label="^ScheduleLabel" status="{scheduleSummary}" buttonlabel="^ScheduleActionLabel" buttonaction="command:openSchedule" navigation="show:SchedulePage" />
      </controls>
    </layout>
    <layout id="SchedulePage" title="^ScheduleTitle" subtitle="{deviceLabel}">
      <controls>
        <textdisplay id="ScheduleSummaryDisplay" title="^ScheduleSummaryTitle" line1label="{selectedScheduleName}" line2label="{scheduleStatusLabel}" line3label="{scheduleSummary}" />
        <selectorbutton id="ScheduleSelector" label="^SelectScheduleLabel" value="{selectedScheduleId}" visible="{scheduleSelectorEnabled}" enabled="{scheduleSelectorEnabled}" />
        <statusandbutton id="EnableScheduleButton" label="^ScheduleEnabledTitle" status="{scheduleStatusLabel}" buttonlabel="^ScheduleEnableActionLabel" buttonaction="command:enableSchedule" visible="{canEnableSchedule}" enabled="{canEnableSchedule}" />
        <statusandbutton id="DisableScheduleButton" label="^ScheduleEnabledTitle" status="{scheduleStatusLabel}" buttonlabel="^ScheduleDisableActionLabel" buttonaction="command:disableSchedule" visible="{canDisableSchedule}" enabled="{canDisableSchedule}" />
        <buttongroup>
          <button id="EditScheduleBtn" label="^EditScheduleLabel" navigation="show:EditSchedulePage" enabled="{scheduleSelectorEnabled}" />
        </buttongroup>
      </controls>
    </layout>
    <layout id="EditSchedulePage" title="^EditScheduleTitle" subtitle="{deviceLabel}">
      <controls>
        <textdisplay id="EditScheduleText" title="^EditScheduleTitle" line1label="^EditScheduleHint1" line2label="^EditScheduleHint2" line3label="{selectedScheduleName}" />
      </controls>
    </layout>
  </layouts>
  <alerts />
</uidefinition>
