<uidefinition xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://prd-use-rad-assets.azurewebsites.net/ExtensionsSchemaDefinition.xsd">
  <version ver="2.0" />
  <tile icon="{platformTileIcon}" status="{platformTileStatus}" navigation="show:MainPage" showinhomepage="#true" showinroompage="#false" />
  <layouts>
    <layout id="MainPage" title="^PlatformTitle" isdefaultlayout="#true">
      <controls>
        <statusandbutton id="HotWaterButton" label="^HotWaterTitle" status="{hotWaterStateLabel}" buttonlabel="{hotWaterActionLabel}" buttonaction="command:toggleHotWater" visible="{hotWaterVisible}" enabled="{hotWaterActionEnabled}" />
        <statusandbutton id="AwayModeButton" label="^AwayTitle" status="{awayModeStateLabel}" buttonlabel="{awayModeActionLabel}" buttonaction="command:toggleAwayMode" visible="{awayModeVisible}" enabled="{awayModeActionEnabled}" />
      </controls>
    </layout>
  </layouts>
  <alerts />
</uidefinition>
